# GEMINI_API_KEY: Required only when media generation endpoints are enabled.
# AI Studio can inject this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Can be injected by AI Studio in hosted environments.
APP_URL="MY_APP_URL"

# JWT_SECRET: Required for signing/verifying auth tokens in server.ts.
JWT_SECRET="your-super-secret-key-change-this"

# DISCORD_GUILD_ID: Discord server ID used by /api/discord/feed (widget API).
# Requires Server Widget enabled in Discord server settings.
DISCORD_GUILD_ID=""

# VITE_ENABLE_STUDIO: Set to "true" to expose /studio.
# Set to "false" (default) to show a coming soon experience.
VITE_ENABLE_STUDIO="false"
