# Server Configuration
NODE_ENV=development
PORT=3000
JWT_SECRET=your-super-secure-jwt-secret-here-at-least-32-characters-long
DATABASE_URL=sqlite.db
# Comma-separated allowlist for browser origins that can call auth APIs cross-origin.
# Leave empty for same-origin deployments.
CLIENT_ORIGIN=

# Payment Providers (optional - at least one required for payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# AI Services (optional)
GEMINI_API_KEY=your_gemini_api_key_here

# Error tracking (optional)
ERROR_TRACKING_WEBHOOK=
VITE_ERROR_TRACKING_WEBHOOK=

# Discord Integration (optional)
DISCORD_GUILD_ID=your_discord_guild_id_here

# Legacy options (may be deprecated)
APP_URL=MY_APP_URL
RESET_DB=false
VITE_ENABLE_STUDIO=false
VITE_API_BASE_URL=

# SMTP mail configuration for transactional emails.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
FROM_EMAIL="no-reply@example.com"

# Optional support contact shown in welcome email template.
SUPPORT_EMAIL="support@example.com"
